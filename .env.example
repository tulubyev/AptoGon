# APTOGON v0.2.0 — единый файл конфигурации
# Скопируй: cp .env.example .env

# ── AI Provider (обязательно) ─────────────────────────────────
# OpenRouter:  GONKA_PROVIDER=openrouter  https://openrouter.ai
# Together.ai: GONKA_PROVIDER=together    https://together.ai
# Ollama:      GONKA_PROVIDER=ollama      (локально, бесплатно)
GONKA_PROVIDER=openrouter
GONKA_API_KEY=sk-or-v1-your-key-here
GONKA_BASE_URL=https://openrouter.ai/api/v1
GONKA_FALLBACK=true

# ── Aptos Blockchain ──────────────────────────────────────────
# Без APTOS_PRIVATE_KEY → работает local store (MVP режим)
APTOS_NODE_URL=https://fullnode.testnet.aptoslabs.com/v1
APTOS_PRIVATE_KEY=
APTOS_NETWORK=testnet
APTOGON_CONTRACT=0x1

# ── Redis ─────────────────────────────────────────────────────
# Бесплатный хостинг: https://upstash.com
REDIS_URL=redis://localhost:6379

# ── App ───────────────────────────────────────────────────────
HSI_ENV=development
